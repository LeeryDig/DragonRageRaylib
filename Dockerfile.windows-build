FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    cmake \
    g++ \
    g++-mingw-w64-x86-64 \
    git \
    make \
    mingw-w64 \
    ninja-build \
    zip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["bash", "scripts/build_windows.sh"]
